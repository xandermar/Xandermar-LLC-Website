---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="https://www.sitemaps.org/schemas/sitemap/0.9">
{% assign sitemap_base_url = site.url | replace: 'http://localhost:4000', 'https://xandermar.com' | replace: 'https://localhost:4000', 'https://xandermar.com' %}
{% assign sitemap_pages = site.pages | where_exp: "item", "item.url != '/404.html' and item.url != '/feed.xml' and item.url != '/sitemap.xml'" %}
{% for item in sitemap_pages %}
  <url>
    <loc>{{ sitemap_base_url }}{{ item.url | relative_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
{% for item in site.posts %}
  <url>
    <loc>{{ sitemap_base_url }}{{ item.url | relative_url }}</loc>
    <lastmod>{{ item.date | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
{% for item in site.category_pages %}
  <url>
    <loc>{{ sitemap_base_url }}{{ item.url | relative_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
</urlset>